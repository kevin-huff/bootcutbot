<!DOCTYPE html>
<html lang="en">
<%
  const rawHellfireSpotIds = Array.isArray(hellfireSpotIds) ? hellfireSpotIds : [];
  const rawHeavenfireSpotIds = Array.isArray(heavenFireSpotIds) ? heavenFireSpotIds : [];
  const initialGlitchIds = [
    ...new Set([...rawHellfireSpotIds, ...rawHeavenfireSpotIds].map((id) => String(id)))
  ].filter((id) => id !== '6');
  const initialBoard = (board || []).map((s) => ({
    id: s && s.id != null ? String(s.id) : '',
    entry: s && s.entry != null ? String(s.entry) : '',
    splot_dot: Number(s && s.splot_dot) || 0,
    alt_entry: s && s.alt_entry != null ? String(s.alt_entry) : '',
    alt_splot_dot: Number(s && s.alt_splot_dot) || 0
  }));
  const initialBreakaways = (breakaways || []).map((b) => ({
    id: b && b.id != null ? String(b.id) : '',
    name: b && b.name != null ? String(b.name) : '',
    ba_dots: Number(b && (b.ba_dots != null ? b.ba_dots : b.ba_dot)) || 0
  }));
%>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bootcut · Board</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=IM+Fell+English+SC&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/oracle.css">
  <script src="/socket.io/socket.io.js"></script>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      background: transparent;
      overflow: hidden;
    }
    body {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      min-height: 100vh;
    }
  </style>
</head>
<body>
  <div class="oracle-root">
    <div class="oracle-board-root" id="oracle-root">

      <header class="oracle-header">
        <span class="arch-corner tl"></span>
        <span class="arch-corner tr"></span>
        <span class="arch-corner bl"></span>
        <span class="arch-corner br"></span>
        <div class="oracle-marquee-lamps top" id="marquee-top"></div>
        <div class="oracle-marquee-lamps bottom" id="marquee-bottom"></div>
        <div class="oracle-presents">Tonight's Broadcast</div>
        <span class="oracle-wordmark"><span>B</span>ootcut</span>
        <div class="oracle-subtitle">!JOIN TO ENTER THE QUEUE</div>
      </header>

      <section class="oracle-status">
        <div class="oracle-player-plaque">
          <svg class="flourish tl" viewBox="0 0 20 20" width="14" height="14" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round">
              <path d="M1 1 H 10"></path><path d="M1 1 V 10"></path>
              <path d="M1 1 Q 6 6 10 10" opacity="0.55"></path>
            </g>
          </svg>
          <svg class="flourish br" viewBox="0 0 20 20" width="14" height="14" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round">
              <path d="M1 1 H 10"></path><path d="M1 1 V 10"></path>
              <path d="M1 1 Q 6 6 10 10" opacity="0.55"></path>
            </g>
          </svg>
          <span class="label">Now Playing</span>
          <span class="name" id="current_player"><%= typeof current_turn !== 'undefined' ? current_turn : '' %></span>
        </div>

        <div class="oracle-timer-jewel">
          <div class="oracle-timer" id="timer_display">
            <svg viewBox="0 0 120 120" class="oracle-timer-ring" aria-hidden="true">
              <defs>
                <linearGradient id="brassGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0" stop-color="#e9c67a"/>
                  <stop offset="0.5" stop-color="#c69a47"/>
                  <stop offset="1" stop-color="#8a6a2d"/>
                </linearGradient>
              </defs>
              <circle cx="60" cy="60" r="54" fill="none" stroke="rgba(214, 178, 99, 0.18)" stroke-width="2"/>
              <circle cx="60" cy="60" r="46" fill="#0e0a1a" stroke="url(#brassGrad)" stroke-width="3"/>
              <circle id="timer_progress" cx="60" cy="60" r="46" fill="none" stroke="rgba(8, 6, 16, 0.65)" stroke-width="6" stroke-dasharray="289.027" stroke-dashoffset="0" transform="rotate(-90 60 60)" style="transition: stroke-dashoffset 0.25s linear;"/>
              <g id="timer_ticks"></g>
            </svg>
            <div class="oracle-timer-face">
              <span class="oracle-timer-value" id="timer_num">00:00</span>
            </div>
          </div>
        </div>

        <div class="oracle-ba-stack" id="ba_stack">
          <div class="oracle-ba-chip" id="ba_chip_chat">
            <span class="oracle-ba-chip-label">CHAT</span>
            <span class="oracle-ba-chip-count" id="ba_count_chat">0</span>
          </div>
          <div class="oracle-ba-chip" id="ba_chip_abba">
            <span class="oracle-ba-chip-label">ABBA</span>
            <span class="oracle-ba-chip-count" id="ba_count_abba">0</span>
          </div>
        </div>
      </section>

      <div class="oracle-grid" id="board"></div>

      <div id="dice_popup_mount"></div>
    </div>
  </div>

  <script>
    /* ============ State ============ */
    const BOARD_DATA = <%- JSON.stringify(initialBoard) %>;
    const INITIAL_BA = <%- JSON.stringify(initialBreakaways) %>;
    const INITIAL_GLITCH = new Set(<%- JSON.stringify(initialGlitchIds) %>);

    const SPLOT_ENTRY_MAX_FONT = 18;
    const SPLOT_ENTRY_MIN_FONT = 8;
    const PLAYER_MAX_FONT = 30;
    const PLAYER_MIN_FONT = 6;

    const state = {
      board: BOARD_DATA.slice(),
      breakaways: INITIAL_BA.slice(),
      glitchIds: new Set(INITIAL_GLITCH),
      activeId: null,
      timerEnd: null,
      timerTotalMs: 0,
      timerRunning: false,
      timerPausedRemaining: null,
      highlightTimeouts: new Map(),
      dicePopupTimer: null
    };

    /* ============ Helpers ============ */
    function normalizeId(v) {
      if (v === null || v === undefined) return '';
      return String(v);
    }
    function escapeHtml(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function padId(id) {
      const n = String(id).replace(/^0+/, '');
      return n.padStart(2, '0');
    }
    function formatMs(ms) {
      if (ms == null || ms < 0) ms = 0;
      const total = Math.floor(ms / 1000);
      const m = Math.floor(total / 60), s = total % 60;
      return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
    }

    /* ============ Marquee lamp strips ============ */
    function renderMarqueeLamps() {
      ['marquee-top', 'marquee-bottom'].forEach((id) => {
        const host = document.getElementById(id);
        if (!host) return;
        host.innerHTML = '';
        const N = 28;
        for (let i = 0; i < N; i++) {
          const lamp = document.createElement('span');
          lamp.className = 'lamp';
          lamp.style.animationDelay = ((i / N) * 1.6).toFixed(3) + 's';
          host.appendChild(lamp);
        }
      });
    }

    /* ============ Timer ring tick marks ============ */
    function renderTimerTicks() {
      const g = document.getElementById('timer_ticks');
      if (!g) return;
      const parts = [];
      for (let i = 0; i < 12; i++) {
        const a = (i / 12) * Math.PI * 2 - Math.PI / 2;
        const x1 = (60 + Math.cos(a) * 52).toFixed(3);
        const y1 = (60 + Math.sin(a) * 52).toFixed(3);
        const x2 = (60 + Math.cos(a) * 48).toFixed(3);
        const y2 = (60 + Math.sin(a) * 48).toFixed(3);
        const w = i % 3 === 0 ? 2 : 1;
        parts.push(`<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="#d6b263" stroke-width="${w}" stroke-linecap="round" opacity="0.85"/>`);
      }
      g.innerHTML = parts.join('');
    }

    /* ============ Splot rendering ============ */
    function pipStringHtml(dots) {
      const n = Math.max(0, Math.min(99, dots | 0));
      if (n > 5) {
        return '<span class="oracle-splot-dots-num"><span class="oracle-pip on"></span><span class="oracle-pip-count">\u00d7' + n + '</span></span>';
      }
      let out = '';
      for (let i = 0; i < n; i++) out += '<span class="oracle-pip on"></span>';
      return out;
    }

    function marqueeBulbHtml(n) {
      let out = '<div class="oracle-marquee" aria-hidden="true">';
      for (let i = 0; i < n; i++) {
        out += '<span class="oracle-bulb" style="--i:' + i + ';--n:' + n + ';animation-delay:' + ((i / n) * 0.9).toFixed(3) + 's"></span>';
      }
      return out + '</div>';
    }

    function splotNode(s) {
      const node = document.createElement('article');
      node.className = 'oracle-splot';
      node.id = 'splot_' + s.id;
      node.dataset.id = s.id;
      node.innerHTML = splotInnerHtml(s);
      applySplotClasses(node, s);
      return node;
    }

    function splotInnerHtml(s) {
      const glitched = state.glitchIds.has(String(s.id));
      const displayEntry = glitched && s.alt_entry ? s.alt_entry : s.entry;
      const displayDots = glitched ? (s.alt_splot_dot || s.splot_dot) : s.splot_dot;
      const isBlank = !displayEntry || String(displayEntry).trim() === '' || displayDots === 0;
      const bodyHtml = isBlank
        ? '<div class="oracle-splot-blank"><span>BLANK</span></div>'
        : '<span class="oracle-splot-entry" id="splotEntry_' + s.id + '">' + escapeHtml(displayEntry) + '</span>';
      return marqueeBulbHtml(28) +
        '<div class="oracle-splot-frame">' +
          '<div class="oracle-splot-inner">' +
            '<div class="oracle-splot-header">' +
              '<span class="oracle-splot-id">' + padId(s.id) + '</span>' +
              '<span class="oracle-splot-dots" title="' + displayDots + ' uses remaining"><span id="splot_dot_' + s.id + '" style="display:none;">' + displayDots + '</span>' + pipStringHtml(displayDots) + '</span>' +
            '</div>' +
            '<div class="oracle-splot-body">' + bodyHtml + '</div>' +
          '</div>' +
        '</div>';
    }

    function applySplotClasses(node, s) {
      const glitched = state.glitchIds.has(String(s.id));
      const displayEntry = glitched && s.alt_entry ? s.alt_entry : s.entry;
      const displayDots = glitched ? (s.alt_splot_dot || s.splot_dot) : s.splot_dot;
      const isBlank = !displayEntry || String(displayEntry).trim() === '' || displayDots === 0;
      node.classList.toggle('is-active', String(state.activeId) === String(s.id));
      node.classList.toggle('is-glitched', glitched);
      node.classList.toggle('is-blank', isBlank);
    }

    function renderBoard() {
      const host = document.getElementById('board');
      if (!host) return;
      host.innerHTML = '';
      state.board.forEach((s) => host.appendChild(splotNode(s)));
      requestAnimationFrame(fitAllSplotEntries);
    }

    function updateBoardSpot(updated) {
      const id = normalizeId(updated.id);
      if (!id) return;
      const idx = state.board.findIndex((s) => String(s.id) === id);
      if (idx < 0) {
        state.board.push({
          id,
          entry: updated.entry || '',
          splot_dot: Number(updated.splot_dot) || 0,
          alt_entry: updated.alt_entry || '',
          alt_splot_dot: Number(updated.alt_splot_dot) || 0
        });
        renderBoard();
        return;
      }
      const merged = Object.assign({}, state.board[idx], updated, { id });
      merged.splot_dot = Number(merged.splot_dot) || 0;
      merged.alt_splot_dot = Number(merged.alt_splot_dot) || 0;
      state.board[idx] = merged;

      const node = document.getElementById('splot_' + id);
      if (!node) {
        renderBoard();
        return;
      }
      node.innerHTML = splotInnerHtml(merged);
      applySplotClasses(node, merged);
      requestAnimationFrame(() => fitSingleSplotEntry(id));
    }

    /* ============ Breakaway chips ============ */
    function findChipId(name) {
      const n = (name || '').toLowerCase();
      if (n.includes('chat')) return 'chat';
      if (n.includes('abba')) return 'abba';
      return null;
    }

    function renderBreakaways() {
      const chat = state.breakaways.find((b) => findChipId(b.name) === 'chat') || { ba_dots: 0 };
      const abba = state.breakaways.find((b) => findChipId(b.name) === 'abba') || { ba_dots: 0 };
      setBaCount('chat', chat.ba_dots, false);
      setBaCount('abba', abba.ba_dots, false);
    }

    function setBaCount(chip, count, awarded) {
      const el = document.getElementById('ba_count_' + chip);
      const chipEl = document.getElementById('ba_chip_' + chip);
      if (!el || !chipEl) return;
      const prev = parseInt(el.textContent, 10) || 0;
      el.textContent = String(count);
      if (awarded && prev !== count) {
        chipEl.classList.remove('just-awarded');
        void chipEl.offsetWidth;
        chipEl.classList.add('just-awarded');
        setTimeout(() => chipEl.classList.remove('just-awarded'), 950);
      }
    }

    function updateBreakaway(ba) {
      const id = normalizeId(ba.id);
      if (!id) return;
      const idx = state.breakaways.findIndex((b) => String(b.id) === id);
      const dots = Number(ba.ba_dots != null ? ba.ba_dots : ba.ba_dot) || 0;
      const entry = { id, name: ba.name || '', ba_dots: dots };
      if (idx < 0) state.breakaways.push(entry);
      else state.breakaways[idx] = Object.assign({}, state.breakaways[idx], entry);
      const chip = findChipId(entry.name);
      if (chip) setBaCount(chip, entry.ba_dots, true);
      else renderBreakaways();
    }

    /* ============ Timer ============ */
    const TIMER_CIRC = 2 * Math.PI * 46;
    function updateTimerDisplay() {
      const valueEl = document.getElementById('timer_num');
      const ringEl = document.getElementById('timer_progress');
      const hostEl = document.getElementById('timer_display');
      if (!valueEl || !ringEl || !hostEl) return;
      let remaining = 0;
      if (state.timerRunning && state.timerEnd) {
        remaining = Math.max(0, state.timerEnd - Date.now());
      } else if (!state.timerRunning && state.timerPausedRemaining != null) {
        remaining = Math.max(0, state.timerPausedRemaining);
      }
      valueEl.textContent = formatMs(remaining);
      const pct = state.timerTotalMs > 0 ? remaining / state.timerTotalMs : 0;
      ringEl.setAttribute('stroke-dasharray', String(TIMER_CIRC));
      ringEl.setAttribute('stroke-dashoffset', String(TIMER_CIRC * (1 - pct)));
      hostEl.classList.toggle('danger', remaining > 0 && remaining < 30_000);
      hostEl.classList.toggle('done', state.timerRunning && remaining === 0);
    }
    setInterval(updateTimerDisplay, 250);

    function handleTimerEvent(msg) {
      if (!msg) return;
      const ms = Number(msg.timer_value);
      if (msg.action === 'set') {
        state.timerTotalMs = Number.isFinite(ms) ? ms : 0;
        state.timerEnd = null;
        state.timerRunning = false;
        state.timerPausedRemaining = state.timerTotalMs;
      } else if (msg.action === 'start') {
        const total = Number.isFinite(ms) ? ms : state.timerTotalMs;
        state.timerTotalMs = total;
        state.timerEnd = Date.now() + total;
        state.timerRunning = true;
        state.timerPausedRemaining = null;
      } else if (msg.action === 'pause') {
        if (state.timerEnd) state.timerPausedRemaining = Math.max(0, state.timerEnd - Date.now());
        state.timerRunning = false;
        state.timerEnd = null;
      } else if (msg.action === 'resume') {
        const rem = state.timerPausedRemaining != null ? state.timerPausedRemaining : 0;
        state.timerEnd = Date.now() + rem;
        state.timerRunning = true;
        state.timerPausedRemaining = null;
      }
      updateTimerDisplay();
    }

    /* ============ Current player (autofit) ============ */
    function fitPlayerName() {
      const el = document.getElementById('current_player');
      if (!el) return;
      const parent = el.parentElement;
      if (!parent) return;
      let size = PLAYER_MAX_FONT;
      el.style.fontSize = size + 'px';
      while (el.scrollWidth > el.clientWidth && size > PLAYER_MIN_FONT) {
        size -= 1;
        el.style.fontSize = size + 'px';
      }
    }
    function setCurrentPlayer(text) {
      const el = document.getElementById('current_player');
      if (!el) return;
      el.textContent = text || '';
      requestAnimationFrame(fitPlayerName);
    }

    /* ============ Splot entry autofit ============ */
    function fitSingleSplotEntry(id) {
      const el = document.getElementById('splotEntry_' + id);
      if (!el) return;
      fitSplotEntryElement(el);
    }
    function fitSplotEntryElement(el) {
      if (!el) return;
      const parent = el.parentElement;
      if (!parent) return;
      let size = SPLOT_ENTRY_MAX_FONT;
      el.style.fontSize = size + 'px';
      const availH = parent.clientHeight;
      const availW = parent.clientWidth;
      while ((el.scrollHeight > availH || el.scrollWidth > availW) && size > SPLOT_ENTRY_MIN_FONT) {
        size -= 1;
        el.style.fontSize = size + 'px';
      }
    }
    function fitAllSplotEntries() {
      document.querySelectorAll('.oracle-splot-entry').forEach(fitSplotEntryElement);
    }

    /* ============ Dice popup ============ */
    function showDice(data) {
      const mount = document.getElementById('dice_popup_mount');
      if (!mount) return;
      mount.innerHTML =
        '<div class="oracle-dice">' +
          '<div class="oracle-dice-card">' +
            '<span class="oracle-dice-type">' + escapeHtml(data.dice_type || '') + '</span>' +
            '<span class="oracle-dice-name">' + escapeHtml(data.dice_name || '') + '</span>' +
            '<span class="oracle-dice-value">' + escapeHtml(String(data.roll_value != null ? data.roll_value : '')) + '</span>' +
            '<span class="oracle-dice-footer">ROLLED</span>' +
          '</div>' +
        '</div>';
      if (state.dicePopupTimer) clearTimeout(state.dicePopupTimer);
      state.dicePopupTimer = setTimeout(() => { mount.innerHTML = ''; state.dicePopupTimer = null; }, 3200);

      if (data.dice_type === 'D12' || data.dice_type === 'D8') {
        flashSplot(String(data.roll_value));
      }
    }
    function flashSplot(id) {
      const node = document.getElementById('splot_' + id);
      if (!node) return;
      node.classList.remove('is-highlighted');
      void node.offsetWidth;
      node.classList.add('is-highlighted');
      if (state.highlightTimeouts.has(id)) clearTimeout(state.highlightTimeouts.get(id));
      state.highlightTimeouts.set(id, setTimeout(() => {
        node.classList.remove('is-highlighted');
        state.highlightTimeouts.delete(id);
      }, 2200));
    }

    /* ============ Activate / deactivate ============ */
    function setActiveSplot(id) {
      state.activeId = id == null ? null : String(id);
      document.querySelectorAll('.oracle-splot').forEach((node) => {
        node.classList.toggle('is-active', String(state.activeId) === node.dataset.id);
      });
    }

    /* ============ Clear board ============ */
    function clearBoard() {
      state.board = [];
      state.glitchIds.clear();
      state.activeId = null;
      document.getElementById('board').innerHTML = '';
    }

    /* ============ Socket wiring ============ */
    function init() {
      renderMarqueeLamps();
      renderTimerTicks();
      renderBoard();
      renderBreakaways();
      setCurrentPlayer(document.getElementById('current_player').textContent || '');

      const socket = io();
      socket.on('connect', () => console.log('board socket connected'));

      socket.on('board_update', (data) => {
        if (!data) return;
        if (typeof data.isAlt === 'boolean') {
          const id = String(data.id);
          if (data.isAlt) state.glitchIds.add(id);
          else state.glitchIds.delete(id);
        }
        updateBoardSpot(data);
      });

      socket.on('alt_splot_swap', (data) => {
        if (!data) return;
        if (Array.isArray(data.hellfireSpotIds) || Array.isArray(data.heavenFireSpotIds)) {
          state.glitchIds.clear();
          [].concat(data.hellfireSpotIds || [], data.heavenFireSpotIds || []).forEach((v) => {
            const id = String(v);
            if (id && id !== '6') state.glitchIds.add(id);
          });
        } else if (typeof data.isAlt === 'boolean') {
          const id = String(data.id);
          if (data.isAlt) state.glitchIds.add(id);
          else state.glitchIds.delete(id);
        }
        updateBoardSpot(data);
      });

      socket.on('ba_update', updateBreakaway);

      socket.on('new_turn', (text) => setCurrentPlayer(text));

      socket.on('timer_server', handleTimerEvent);

      socket.on('dice_rolled', showDice);

      socket.on('clear_board', clearBoard);

      socket.on('splot_activated', (data) => {
        if (data && (data.splot_id || data.id)) {
          setActiveSplot(String(data.splot_id != null ? data.splot_id : data.id));
        }
      });
      socket.on('splot_deactivated', () => setActiveSplot(null));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
</body>
</html>
