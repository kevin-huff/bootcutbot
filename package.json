{
  "name": "glitch-mvp-node",
  "version": "0.0.1",
  "description": "BootcutBot for Bootcut on Twitch",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "migrate-assets": "node scripts/migrateAssets.js",
    "db:schema": "node scripts/initSchema.js",
    "db:migrate": "node scripts/migrateJsonToPg.js",
    "db:migrate:dry": "node scripts/migrateJsonToPg.js --dry",
    "dev:board": "vite",
    "build:board": "vite build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.488.0",
    "@twurple/api": "^7.2.1",
    "@twurple/auth": "^7.2.1",
    "@twurple/eventsub-ws": "^7.2.1",
    "api": "^6.1.1",
    "censor-sensor": "^1.0.6",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.6",
    "elevenlabs-node": "^2.0.3",
    "express": "^4.17.2",
    "express-basic-auth": "^1.2.1",
    "fetch": "^1.1.0",
    "moment-timezone": "^0.5.43",
    "openai": "3.2.1",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "request": "^2.88.2",
    "simplex-noise": "^4.0.3",
    "socket.io": "^4.5.0",
    "socket.io-client": "^4.7.4",
    "spoken": "^1.1.17",
    "tmi.js": "^1.8.5"
  },
  "engines": {
    "node": "16"
  },
  "repository": {
    "url": "https://glitch.com/edit/#!/glitch-mvp-node"
  },
  "nodemonConfig": {
    "ignore": [
      "*.json"
    ]
  },
  "license": "MIT",
  "keywords": [
    "node",
    "glitch",
    "express",
    "bootcut",
    "twitch",
    "openai"
  ],
  "devDependencies": {
    "@vitejs/plugin-react": "^3.1.0",
    "jest": "^29.7.0",
    "vite": "^4.5.0"
  }
}
