<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Bootcut · Ticker</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=IM+Fell+English+SC&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/oracle.css">
  <script src="/socket.io/socket.io.js"></script>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      background: transparent;
      overflow: hidden;
    }
    body { display: flex; justify-content: flex-start; align-items: flex-end; min-height: 100vh; padding: 20px; }
    .ticker-stage { transition: opacity 0.4s ease, transform 0.4s ease; opacity: 0; transform: translateY(14px); }
    .ticker-stage.visible { opacity: 1; transform: translateY(0); }
  </style>
</head>
<body>
  <div class="oracle-root">
    <div class="ticker-stage" id="ticker_container">
      <div class="oracle-ticker">
        <div class="oracle-ticker-frame">
          <div class="oracle-ticker-body">
            <div class="oracle-ticker-row1">
              <span class="oracle-ticker-badge">Active Splot</span>
              <span class="oracle-ticker-elapsed" id="elapsed">00:00</span>
            </div>
            <div class="oracle-ticker-entry" id="splot_entry">&nbsp;</div>
            <div class="oracle-ticker-row2">
              <span class="oracle-ticker-rolledby">rolled by <b id="rolled_by">&nbsp;</b></span>
            </div>
            <div class="oracle-ticker-cta-row">
              <span class="oracle-ticker-cta">!join for your turn</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const INITIAL_ACTIVE = <%- JSON.stringify(typeof active_splot !== 'undefined' && active_splot ? active_splot : null) %>;

    const container = document.getElementById('ticker_container');
    const entryEl = document.getElementById('splot_entry');
    const rolledByEl = document.getElementById('rolled_by');
    const elapsedEl = document.getElementById('elapsed');

    let activatedAt = null;
    let timerInterval = null;

    function formatElapsed(ms) {
      const totalSeconds = Math.max(0, Math.floor(ms / 1000));
      const m = Math.floor(totalSeconds / 60);
      const s = totalSeconds % 60;
      return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
    }
    function tickElapsed() {
      if (!activatedAt) return;
      elapsedEl.textContent = formatElapsed(Date.now() - activatedAt);
    }
    function startTimer(ts) {
      if (timerInterval) clearInterval(timerInterval);
      activatedAt = ts || Date.now();
      tickElapsed();
      timerInterval = setInterval(tickElapsed, 1000);
    }
    function stopTimer() {
      if (timerInterval) clearInterval(timerInterval);
      timerInterval = null;
      activatedAt = null;
      elapsedEl.textContent = '00:00';
    }

    function showTicker(data) {
      if (!data) return;
      entryEl.textContent = data.entry || '';
      rolledByEl.textContent = data.rolled_by || '';
      startTimer(data.activated_at);
      container.classList.add('visible');
    }
    function hideTicker() {
      container.classList.remove('visible');
      stopTimer();
    }

    if (INITIAL_ACTIVE) showTicker(INITIAL_ACTIVE);

    const socket = io();
    socket.on('connect', () => console.log('ticker connected'));
    socket.on('splot_activated', showTicker);
    socket.on('splot_deactivated', hideTicker);
  </script>
</body>
</html>
