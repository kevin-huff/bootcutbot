<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Board Admin</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <!-- Bootstrap (kept for modals + toasts) -->
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" integrity="sha384-ggOyR0iXCbMQv3Xipma34MD+dH/1fQ784/j6cY/iJTQUOhcWr7x9JvoRxT2MZw1T" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@forevolve/bootstrap-dark@1.0.0/dist/css/bootstrap-dark.min.css" />
  <link rel="stylesheet" href="//code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">

  <!-- Arcade fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700;800&display=swap" rel="stylesheet">

  <!-- Legacy site css first, then arcade overrides -->
  <link rel="stylesheet" href="style.css?v=<%= BUILD_VERSION %>">
  <link rel="stylesheet" href="css/arcade-board-admin.css?v=<%= BUILD_VERSION %>">

  <script src="https://kit.fontawesome.com/5a69a86b05.js" crossorigin="anonymous"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js" integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.12.9/dist/umd/popper.min.js" integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q" crossorigin="anonymous"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.1/js/bootstrap.bundle.min.js"></script>
  <script src="/tmi.min.js"></script>
  <script src="https://stephenlb.github.io/spoken/spoken.js"></script>
  <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.js"></script>
  <script src="godice.js?v=<%= BUILD_VERSION %>"></script>
  <script src="main.js?v=<%= BUILD_VERSION %>" data="<%= JSON.stringify(data) %>"></script>
</head>
<body class="arcade-admin">

  <!-- toast container -->
  <div id="messages-list"></div>

  <!-- audio tags preserved -->
  <audio id="fart_0" src="/farts/fart_0.wav"></audio>
  <audio id="fart_1" src="/farts/fart_1.wav"></audio>
  <audio id="fart_2" src="/farts/fart_2.wav"></audio>
  <audio id="fart_3" src="/farts/fart_3.wav"></audio>
  <audio id="fart_4" src="/farts/fart_4.wav"></audio>
  <audio id="fart_5" src="/farts/fart_5.wav"></audio>
  <audio id="fart_6" src="/farts/fart_6.wav"></audio>
  <audio id="fart_7" src="/farts/fart_7.wav"></audio>
  <audio id="fart_8" src="/farts/fart_8.wav"></audio>
  <audio id="fart_9" src="/farts/fart_9.wav"></audio>
  <audio id="win_sound" src="/win.mp3"></audio>
  <audio id="lose_sound" src="/lose.mp3"></audio>

  <!-- ============ STATUS BAR ============ -->
  <header class="status-bar">
    <div class="sb-logo">
      <span class="sb-mark">B</span>
      <span class="sb-title">
        <small>BOOTCUTBOT / ADMIN</small>
        <span>Board Control</span>
      </span>
    </div>
    <div class="sb-cell sb-live">
      <span class="led led--live"></span>
      <div>
        <small>STREAM</small>
        <span class="sb-value" id="sb-stream">LIVE</span>
      </div>
    </div>
    <div class="sb-cell">
      <span class="led <%= data.queue_open ? 'on' : '' %>" id="sb-queue-led"></span>
      <div>
        <small>QUEUE</small>
        <span class="sb-value" id="sb-queue"><%= (data.queue && data.queue.length) || 0 %> &middot; <%= data.queue_open ? 'OPEN' : 'CLOSED' %></span>
      </div>
    </div>
    <div class="sb-cell">
      <span class="led" id="sb-dice-led"></span>
      <div>
        <small>GODICE</small>
        <span class="sb-value" id="sb-dice">0/0</span>
      </div>
    </div>
    <div class="sb-cell">
      <span class="led on" id="sb-ai-led"></span>
      <div>
        <small>AI</small>
        <span class="sb-value" id="sb-ai">Abbadabbabot</span>
      </div>
    </div>
    <div class="sb-cell">
      <span class="led on"></span>
      <div>
        <small>TURN</small>
        <span class="sb-value" id="sb-turn"><%= data.current_turn %></span>
      </div>
    </div>
    <div class="sb-spacer"></div>
    <div class="sb-actions">
      <button class="pill pill--ghost pill--sm" id="open-commands" type="button"><span>&#x2318;</span> Commands</button>
      <button class="pill pill--danger pill--ghost pill--sm" onclick="clearBoard()" type="button">Clear Board</button>
    </div>
  </header>

  <!-- ============ MAIN SHELL ============ -->
  <div class="arcade-shell">

    <!-- Player + Timer row -->
    <section class="player-timer">
      <div class="player">
        <div class="kicker"><span class="led led--live"></span> NOW UP</div>
        <h1 id="current_player"></h1>
        <small class="player-meta">turn <span id="player-turn-num"><%= data.current_turn %></span></small>
        <div class="pill-row">
          <button type="button" class="pill pill--hot pill--lg" id="nextPick">&#9654; Next</button>
          <button type="button" class="pill pill--lg" id="randomPick">&#9830; Random</button>
          <button type="button" class="pill pill--lg" id="autoPick">&#9678; Auto Pick</button>
          <span class="splot-spacer"></span>
          <button type="button" class="pill" data-toggle="modal" data-target="#addSplot">&#43; Add Splot</button>
          <button type="button" class="pill pill--ghost" data-toggle="modal" data-target="#addBreakaway">&#43; Breakaway</button>
          <button type="button" class="pill pill--ghost" id="toggle_ai">AI &middot; Toggle</button>
        </div>
      </div>
      <div class="timer">
        <div class="timer-head">
          <span class="led led--warn"></span>
          <small>TURN TIMER</small>
          <span class="grow"></span>
          <input type="text" id="timer" placeholder="4:00" value="4:00">
        </div>
        <h2 id="timer_display">0:00</h2>
        <div class="timer-bar"><span id="timer-bar-fill"></span></div>
        <div class="pill-row">
          <button class="pill pill--sm pill--ghost d-none" id="resume">&#9654; Resume</button>
          <button class="pill pill--sm pill--ghost d-none" id="pause">&#x2016; Pause</button>
          <button class="pill pill--sm pill--ghost" id="reset" onclick="startTimer()">&#8635; Reset</button>
        </div>
      </div>
    </section>

    <!-- Main grid: splot board + right rail -->
    <div class="arcade-main">

      <!-- Splot board -->
      <section>
        <div class="arcade-section-head">
          <span class="title">Board</span>
          <span class="count" id="splot-count"><%= (data.board && data.board.length) || 0 %> splots</span>
          <span class="grow"></span>
          <button class="pill pill--sm" data-toggle="modal" data-target="#addSplot" type="button">&#43; Add Splot</button>
        </div>

        <div id="board">
          <% (data.board || []).forEach(function(dataRow) { %>
            <article class="splot" id="splot_<%= dataRow.id %>">
              <span class="splot-id">#<%= String(dataRow.id).padStart(2, '0') %></span>
              <div class="splot-body">
                <p class="splot-entry" id="splotEntry_<%= dataRow.id %>"><%= dataRow.entry %></p>

                <% if (dataRow.alt_entry) { %>
                  <div class="splot-alt">
                    <small>ALT &middot; <span id="alt_splot_dot_<%= dataRow.id %>"><%= dataRow.alt_splot_dot %></span> DOTS</small>
                    <span id="altSplotEntry_<%= dataRow.id %>"><%= dataRow.alt_entry %></span>
                  </div>
                <% } %>

                <div class="splot-dots">
                  <small>DOTS</small>
                  <span class="dots" data-value="<%= dataRow.splot_dot %>">
                    <% for (var i = 0; i < 10; i++) { %>
                      <span class="dot <%= i < dataRow.splot_dot ? 'filled' : '' %>"></span>
                    <% } %>
                  </span>
                  <span class="splot-dot-n"><strong id="splot_dot_<%= dataRow.id %>"><%= dataRow.splot_dot %></strong>/10</span>
                </div>

                <div class="splot-actions">
                  <button class="ibtn" title="Decrease" onclick="splotDotDecrease('<%= dataRow.id %>')">&minus;</button>
                  <button class="ibtn" title="Increase" onclick="splotDotIncrease('<%= dataRow.id %>')">&#43;</button>
                  <button class="ibtn ibtn--hot activate-splot-btn" id="activate_splot_<%= dataRow.id %>" title="Activate (Now Playing)" onclick="activateSplot('<%= dataRow.id %>')">&#9654;</button>
                  <button class="ibtn" title="Complete" onclick="completeSplot(<%= dataRow.id %>)">&#10003;</button>
                  <span class="splot-spacer"></span>
                  <button class="ibtn" title="Edit" onclick="popEditModal(<%= dataRow.id %>)">&#9998;</button>
                  <button class="ibtn swap_splot" title="Swap Alt" onclick="swapSplot(<%= dataRow.id %>)">&#8646;</button>
                  <button class="ibtn" title="BA Replace" onclick="breakAwaySplot('<%= dataRow.id %>')">&#9856;</button>
                </div>
              </div>
            </article>
          <% }); %>
        </div>

        <% if (!data.board || data.board.length === 0) { %>
          <div class="queue-empty">Board is empty &middot; press + Add Splot to begin</div>
        <% } %>
      </section>

      <!-- Right rail -->
      <aside class="side-rail">
        <!-- Dice panel -->
        <div class="panel">
          <div class="panel-head">
            <span class="led" id="dice-led"></span>
            <small id="dice-panel-label">GODICE &middot; DISCONNECTED</small>
            <span class="grow"></span>
            <label class="fake-rolls">
              <input type="checkbox" id="fakeRollsOnly" autocomplete="off">
              Fake Rolls
            </label>
          </div>
          <div class="panel-body">
            <button type="button" class="pill pill--sm" onclick="openConnectionDialog()">Connect GoDice</button>
            <div id="dice-host" style="margin-top: 12px;"></div>
            <div class="force-roll" style="margin-top: 14px; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 12px;">
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                <small style="font-family:var(--font-mono);letter-spacing:.14em;color:var(--ink-2);">FORCE D8 ROLL</small>
              </div>
              <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;">
                <% for (var i = 1; i <= 8; i++) { %>
                  <button type="button" class="pill pill--sm pill--ghost" onclick="triggerFakeD8Roll(<%= i %>)"><%= i %></button>
                <% } %>
              </div>
            </div>
          </div>
          <div id="roll-log"></div>
          <div id="dice-message-container"></div>
        </div>

        <!-- Queue panel -->
        <div class="panel">
          <div class="panel-head">
            <span class="led <%= data.queue_open ? 'on' : '' %>"></span>
            <small>QUEUE &middot; <%= (data.queue && data.queue.length) || 0 %> &middot; <%= data.queue_open ? 'OPEN' : 'CLOSED' %></small>
            <span class="grow"></span>
            <button type="button"
                    id="toggle_virgins_first"
                    class="pill pill--sm <%= data.virgins_first ? '' : 'pill--ghost' %>"
                    data-active="<%= data.virgins_first ? '1' : '0' %>"
                    title="Prioritize players who have never played before (Virgin-Virgin-Next auto-pick)"
                    style="margin-right:6px;">
              VIRGINS FIRST <%= data.virgins_first ? 'ON' : 'OFF' %>
            </button>
            <button type="button"
                    id="toggle_firsts_first"
                    class="pill pill--sm <%= data.firsts_first ? '' : 'pill--ghost' %>"
                    data-active="<%= data.firsts_first ? '1' : '0' %>"
                    title="Prioritize players with zero turns this session">
              FIRSTS FIRST <%= data.firsts_first ? 'ON' : 'OFF' %>
            </button>
          </div>
          <div class="queue-list" id="queue-list">
            <% if (data.queue && data.queue.length > 0) { %>
              <% data.queue.forEach(function(q, i) {
                   var name = q['display-name'] || q.username || 'unknown';
                   var turns = (q.turn_count != null) ? q.turn_count : 0;
                   var isFirst = turns === 0;
              %>
                <div class="queue-row <%= i === 0 ? 'is-next' : '' %>">
                  <span class="pos"><%= String(i + 1).padStart(2, '0') %></span>
                  <span class="name">
                    <%= name %>
                    <% if (isFirst) { %><span class="first-tag">1ST</span><% } %>
                  </span>
                  <span class="turns"><%= turns %> turn<%= turns === 1 ? '' : 's' %></span>
                </div>
              <% }); %>
            <% } else { %>
              <div class="queue-empty">Queue is empty</div>
            <% } %>
          </div>
        </div>
      </aside>
    </div>

    <!-- Breakaways row -->
    <section>
      <div class="arcade-section-head">
        <span class="title">Breakaways</span>
        <span class="count" id="ba-count"><%= (data.breakaways && data.breakaways.length) || 0 %> tracked</span>
        <span class="grow"></span>
        <button class="pill pill--sm" data-toggle="modal" data-target="#addBreakaway" type="button">&#43; Add Breakaway</button>
      </div>
      <div id="breakaways">
        <% (data.breakaways || []).forEach(function(dataRow) { %>
          <article class="ba" id="breakaway_<%= dataRow.id %>">
            <small class="ba-kicker">BREAKAWAY</small>
            <div class="ba-row">
              <h3 id="breakawayName_<%= dataRow.id %>"><%= dataRow.name %></h3>
              <span class="ba-count" id="ba_dot_<%= dataRow.id %>"><%= dataRow.ba_dots %></span>
            </div>
            <div class="ba-actions">
              <button class="ibtn ibtn--sm" title="Decrease" onclick="breakawayDecrease('<%= dataRow.id %>')">&minus;</button>
              <button class="ibtn ibtn--sm" title="Increase" onclick="breakawayIncrease('<%= dataRow.id %>')">&#43;</button>
              <span class="splot-spacer"></span>
              <button class="ibtn ibtn--sm" title="Edit" onclick="popEditBreakawayModal(<%= dataRow.id %>)">&#9998;</button>
            </div>
          </article>
        <% }); %>
      </div>
    </section>

    <!-- Footer status strip -->
    <div class="arcade-footer">
      <span id="foot-socket">SOCKET.IO CONNECTED</span>
      <span>&middot;</span>
      <span id="foot-sync">SYNC 00:00:00</span>
      <span class="grow"></span>
      <span>PRESS <span class="hotkey">&#x2318;K</span> FOR COMMANDS</span>
    </div>

    <!-- spoken.js controls (less prominent) -->
    <div style="margin-top: 4px;">
      <button id="listening_button" type="button">Start listening</button>
      <div id="listening_result"></div>
    </div>
  </div>

  <!-- ============ COMMANDS DRAWER ============ -->
  <div class="arcade-drawer-backdrop" id="commands-backdrop"></div>
  <aside class="arcade-drawer" id="commands-drawer" aria-hidden="true">
    <div class="drawer-head">
      <span class="title">Commands</span>
      <span class="kbd">&#x2318;K</span>
      <span class="grow"></span>
      <button type="button" class="esc" id="close-commands">ESC</button>
    </div>
    <div class="drawer-search">
      <div class="drawer-search-inner">
        <span class="slash">/</span>
        <input type="text" id="commands-search" placeholder="search commands&hellip;" autocomplete="off" spellcheck="false">
      </div>
    </div>
    <div class="drawer-body" id="drawer-body">
      <%
        var commandGroups = [
          { title: 'QUEUE · ADMIN', cmds: [
            ['!clear_all', 'Clear queue and turn counts'],
            ['!clear_queue', 'Clear queue only'],
            ['!open', 'Open queue to joiners'],
            ['!close', 'Close queue'],
            ['!firsts_first', 'Toggle firsts-turns-first mode (session)'],
            ['!virgins_first', 'Toggle virgins-first mode (all-time)'],
            ['!ap', 'Toggle auto-pick'],
            ['!next', 'Pick next user'],
            ['!random', 'Pick random user'],
            ['!virgin', 'Pick random first-time player (falls back to !random)'],
            ['!abbadabbabot', 'Send prompt to Abbadabbabot'],
            ['!warn', 'Cheeky warning DM']
          ]},
          { title: 'QUEUE · USER', cmds: [
            ['!join', 'Join the queue'],
            ['!leave', 'Leave the queue'],
            ['!position', 'Tell caller their position'],
            ['!auto_splot', 'AI suggests a splot on your turn'],
            ['!dn_count', 'Deeze Nutz jokie count'],
            ['!deeznutz', 'AI deeznutz joke'],
            ['!justice', 'Reminds chat about old justice'],
            ['!cherish', 'Abbabox cherishes your butt']
          ]},
          { title: 'RATINGS & YOUTUBE', cmds: [
            ['!open_ratings', 'Uncap !rating commands'],
            ['!close_ratings', 'Cap !rating commands'],
            ['!rate {t}|{n}', 'Save a rating'],
            ['!rating {t}', 'Look up a rating'],
            ['!ratings', 'Link to ratings page'],
            ['!open_yt', 'Open YouTube link capture'],
            ['!close_yt', 'Close YouTube capture'],
            ['!list_yt', 'Show YT queue']
          ]}
        ];
      %>
      <% commandGroups.forEach(function(group) { %>
        <div class="drawer-group">
          <div class="group-title"><%= group.title %></div>
          <% group.cmds.forEach(function(row) { %>
            <div class="drawer-cmd" data-cmd="<%= row[0].toLowerCase() %>" data-desc="<%= row[1].toLowerCase() %>">
              <code><%= row[0] %></code>
              <span><%= row[1] %></span>
            </div>
          <% }); %>
        </div>
      <% }); %>
    </div>
    <div class="drawer-foot">
      <span>ESC TO CLOSE</span>
      <span class="grow"></span>
      <a href="https://bootcutbot.glitch.me/" style="color: var(--ink-2); text-decoration: none;">THE LIST</a>
      <a href="https://bootcutbot.glitch.me/youtube" style="color: var(--ink-2); text-decoration: none;">YT ADMIN</a>
    </div>
  </aside>

  <!-- ============ MODALS (arcade skin, same IDs/handlers) ============ -->
  <div class="modal fade arcade" id="addSplot" tabindex="-1" role="dialog" aria-labelledby="addSplotTitle" aria-hidden="true">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <span class="modal-kicker">+ NEW</span>
          <h5 class="modal-title" id="addSplotTitle">Add a Splot</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <form id="addSplotForm">
            <div class="form-group">
              <label for="addSplotEntry">Splot Entry</label>
              <textarea class="form-control splotEntry" id="addSplotEntry" rows="3">Blank Splot</textarea>
            </div>
            <div class="form-group">
              <label for="addSplotDot">Splot Dots</label>
              <select class="form-control" id="addSplotDot">
                <% for (var i = 1; i <= 10; i++) { %><option value="<%= i %>"><%= i %></option><% } %>
              </select>
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="pill pill--ghost" data-dismiss="modal">Close</button>
          <button type="button" onclick="get_random_splot()" class="pill">&#9856; Random Splot</button>
          <button type="button" onclick="addSplot()" class="pill pill--hot">Add Splot</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade arcade" id="addBreakaway" tabindex="-1" role="dialog" aria-labelledby="addBreakawayTitle" aria-hidden="true">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <span class="modal-kicker">+ NEW</span>
          <h5 class="modal-title" id="addBreakawayTitle">Add a Breakaway</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <form id="addBreakawayForm">
            <div class="form-group">
              <label for="addBreakawayName">Breakaway Name</label>
              <textarea class="form-control" id="addBreakawayName" rows="2">Custom Breakaway</textarea>
            </div>
            <div class="form-group">
              <label for="breakawayDots">Breakaway Dots</label>
              <input type="number" class="form-control" id="breakawayDots" value="10">
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="pill pill--ghost" data-dismiss="modal">Close</button>
          <button type="button" onclick="addBreakaway()" class="pill pill--hot">Add Breakaway</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade arcade" id="editBreakaway" tabindex="-1" role="dialog" aria-labelledby="editBreakawayTitle" aria-hidden="true">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <span class="modal-kicker">EDIT</span>
          <h5 class="modal-title" id="editBreakawayTitle">Edit Breakaway</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <form id="editBreakawayForm">
            <input type="hidden" name="editBreakawayId" id="editBreakawayId" value="0" />
            <div class="form-group">
              <label for="editBreakawayName">Breakaway Name</label>
              <textarea class="form-control" id="editBreakawayName" rows="2">Custom Breakaway</textarea>
            </div>
            <div class="form-group">
              <label for="addBreakawayDots">Breakaway Dots</label>
              <input type="number" class="form-control" id="addBreakawayDots" value="10">
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="pill pill--ghost" data-dismiss="modal">Close</button>
          <button type="button" onclick="editSplot()" class="pill pill--hot">Save Changes</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade arcade" id="editSplot" tabindex="-1" role="dialog" aria-labelledby="editSplotTitle" aria-hidden="true">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <span class="modal-kicker">EDIT</span>
          <h5 class="modal-title" id="editSplotTitle">Edit Splot</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <form id="editSplotForm">
            <input type="hidden" name="editSplotId" id="editSplotId" value="0" />
            <div class="form-group">
              <label for="editSplotEntry">Splot Entry</label>
              <textarea class="form-control splotEntry" id="editSplotEntry" rows="3"></textarea>
            </div>
            <div class="form-group">
              <label for="editSplotDot">Splot Dots</label>
              <select class="form-control" id="editSplotDot">
                <% for (var i = 1; i <= 10; i++) { %><option value="<%= i %>"><%= i %></option><% } %>
              </select>
            </div>
            <div class="form-group">
              <label for="editAltSplotEntry">Alt Splot</label>
              <textarea class="form-control altSplotEntry" id="editAltSplotEntry" rows="3"></textarea>
            </div>
            <div class="form-group">
              <label for="editAltSplotDot">Alt Splot Dots</label>
              <select class="form-control" id="editAltSplotDot">
                <% for (var i = 1; i <= 10; i++) { %><option value="<%= i %>"><%= i %></option><% } %>
              </select>
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="pill pill--ghost" data-dismiss="modal">Close</button>
          <button type="button" onclick="get_random_splot()" class="pill">&#9856; Random Splot</button>
          <button type="button" onclick="editSplot()" class="pill pill--hot">Save Changes</button>
        </div>
      </div>
    </div>
  </div>

</body>
</html>
